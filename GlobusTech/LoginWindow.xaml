<Window x:Class="GlobusTech.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GlobusTech"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="400">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Margin="20">
 
            <Label Content="Авторизируйтесь для входа в систему"></Label>
            <Label Margin="20" Content="Логин" HorizontalAlignment="Center"></Label>
            <TextBox x:Name="LoginBox" Width="200"></TextBox>
            <Label Margin="20" Content="Пароль" HorizontalAlignment="Center"></Label>
            <PasswordBox x:Name="PasswordBox" Width="200"></PasswordBox>
            <Button x:Name="LoginButton" Width="100" Margin="10" Content="Войти" Click="LoginButton_Click"></Button>
            <Button x:Name="GuestButton" Width="100" Margin="10" Content="Войти как гость" Click="GuestButton_Click"></Button>

        </StackPanel>
    </Grid>
</Window>
