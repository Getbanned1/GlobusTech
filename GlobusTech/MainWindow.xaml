<Window x:Class="GlobusTech.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GlobusTech"
        mc:Ignorable="d"
        Title="Глобус технолоджи" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel x:Name="NavigationPanel" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal" Grid.Row="0" Margin="10,10,10,10">
            <Button x:Name="ServicesNavButton" Width="100" Content="It-услуги" Margin="0,0,10,0" Click="ServicesNavButton_Click"></Button>
            <Button x:Name="ApplicationsNavButton" Width="100" Content="Заявки"  Margin="0,0,10,0" Click="ApplicationsNavButton_Click"></Button>
            <Button x:Name="UsersNavButton" Width="100" Content="Пользователи"  Margin="0,0,10,0" Click="UsersNavButton_Click"></Button>
        </StackPanel>
        <Frame x:Name="MainFrame" Grid.Row="1" VerticalAlignment="Stretch"></Frame>
    </Grid>
</Window>
