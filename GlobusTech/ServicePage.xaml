<Page x:Class="GlobusTech.ServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GlobusTech"
      mc:Ignorable="d" 
      d:DesignHeight="250" d:DesignWidth="800"
      Title="ServicePage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition> 
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" x:Name="SearchBar" HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="Поиск" ></Label>
            <TextBox x:Name="SearchBox" Width="150" TextChanged="SearchBox_TextChanged" ></TextBox>
            <Label Content="Сортировать по дате"></Label>
            <ComboBox x:Name="DateSortBox" Width="100" SelectionChanged="DateSortBox_SelectionChanged"></ComboBox>
        </StackPanel>
        <ListBox x:Name="ServiceCard" Grid.Row="1" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" Background="{Binding BackgroundBrush}" CornerRadius="8" Margin="10">
                        <Grid Width="1000">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="200"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"></RowDefinition>
                                <RowDefinition Height="50"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Image Grid.Column="0" Source="{Binding FilePath}" Stretch="Uniform"></Image>
                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="{Binding Name}"></TextBlock>
                                <TextBlock Text="{Binding ServiceSphere.Name}"></TextBlock>
                                <TextBlock Text="{Binding Duration, StringFormat='Продолжительность: {0}'}"></TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="10" Orientation="Horizontal">
                                <TextBlock Text="{Binding Price ,StringFormat='Стоимость: {0}'}"></TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="10" Orientation="Horizontal">
                                <TextBlock Text="{Binding StartDate,StringFormat='Дата начала: {0}'}"></TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="10" Orientation="Horizontal">
                                <TextBlock Text="{Binding AvalibleSlots ,StringFormat='Cлоты для заявки: {0}'}"></TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
